{
  "manifest_version": 3,
  "name": "BranchPanda",
  "version": "1.0.0",
  "description": "Explore GitHub repositories right from your browser.",
  "action": {
    "default_popup": "index.html",
    "default_title": "BranchPanda"
  },
  "permissions": [],
  "host_permissions": [
    "https://api.github.com/*",
    "https://raw.githubusercontent.com/*",
    "https://github.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "index.html",
        "assets/*",
        "favicon-16.png",
        "favicon-48.png",
        "favicon-128.png"
      ],
      "matches": [
        "https://github.com/*"
      ]
    }
  ],
  "icons": {
    "16": "favicon-16.png",
    "48": "favicon-48.png",
    "128": "favicon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "branchpanda@extension",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}